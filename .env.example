TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
APP_NAME=Anua
APP_VERSION=0.0.0
SESSION_DRIVER=cookie

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=anua_v2
RESEND_API_KEY=

# Storage
DRIVE_DISK=fs
GCS_BUCKET=
GCS_KEY_FILENAME=

# Asaas Payment Gateway
ASAAS_API_KEY=
ASAAS_WEBHOOK_URL=
ASAAS_WEBHOOK_TOKEN=

# PostHog
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=Anua
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORT_TARGET=collector
OTEL_COLLECTOR_ENDPOINT=http://localhost:4318

# evlog (wide events)
EVLOG_ENABLED=true
EVLOG_DRAIN_TARGET=none
EVLOG_POSTHOG_HOST=https://us.i.posthog.com

# PostHog OTEL (optional)
# Use project token (phc_), not personal token (phx_)
POSTHOG_PROJECT_TOKEN=
POSTHOG_OTEL_ENDPOINT_BASE=https://us.i.posthog.com/i
