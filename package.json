{
  "name": "anua-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "concurrently -k -n server,queue,scheduler -c blue,magenta,yellow \"PORT=3333 node ace serve --hmr\" \"PORT=8081 DISABLE_SCHEDULER=1 node ace queue:work\" \"node ace scheduler:run\"",
    "dev:server": "PORT=3333 node ace serve --hmr",
    "dev:server:portless": "portless anua node ace serve --hmr",
    "dev:queue": "DISABLE_SCHEDULER=1 node ace queue:work",
    "dev:scheduler": "node ace scheduler:run",
    "test": "node ace test",
    "test:browser": "node ace test browser",
    "test:queue": "node ace test functional --files tests/functional/queue/jobs_dispatch.spec.ts --files tests/functional/queue/jobs_execution.spec.ts",
    "test:queue:pglite": "pglite-server --db=memory:// --host=127.0.0.1 --port=55432 --run \"sh scripts/run_queue_tests_with_pglite.sh\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:inertia": "tsc -p inertia/tsconfig.json --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#dtos/*": "./app/dtos/*.js",
    "#jobs/*": "./app/jobs/*.js",
    "#audit_resolvers/*": "./app/audit_resolvers/*.js",
    "#lib/*": "./app/lib/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js"
  },
