{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-cursor-oauth"
  ],
  "provider": {
    "cursor": {
      "name": "Cursor"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      ".turbo/**",
      "dist/**",
      "build/**",
      "coverage/**"
    ]
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    }
  }
}
