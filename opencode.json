{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-cursor-oauth", "opencode-gemini-auth@latest"],
  "provider": {
    "cursor": {
      "name": "Cursor"
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", ".next/**", ".turbo/**", "dist/**", "build/**", "coverage/**"]
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "quaveone": {
      "type": "remote",
      "url": "https://mcp.quave.cloud/",
      "headers": {
        "authorization": "desktop-q7gtckxhhvjdnc8va-4crezdmyrwnhnbcpw"
      }
    }
  }
}
