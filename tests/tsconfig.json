{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "@types/node",
      "@japa/runner/types",
      "@japa/assert/types",
      "@japa/api-client/types",
      "@japa/browser-client/types"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.spec.ts",
    "./types/**/*.d.ts",
    "../config/auth.ts",
    "../.adonisjs/server/**/*.d.ts"
  ],
  "exclude": ["../node_modules", "../build", "../inertia", "../.adonisjs/client"]
}
